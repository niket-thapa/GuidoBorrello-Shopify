{% liquid
  assign eyebrow = section.settings.eyebrow
  assign heading = section.settings.heading
  assign description = section.settings.description
%}

<!-- Recipes page header – same structure and animations as reference (ricette.html) -->
<section class="py-20 md:py-28 bg-card recipes-header-section" {{ section.shopify_attributes }}>
  <div class="max-w-7xl mx-auto px-6 text-center">
    {% if eyebrow != blank %}
      <p class="ricette-header-item ricette-delay-0 text-[10px] font-sans font-medium uppercase tracking-[0.3em] text-muted-foreground mb-3">
        {{ eyebrow | escape }}
      </p>
    {% endif %}
    {% if heading != blank %}
      <h2 class="ricette-header-item ricette-delay-1 font-serif text-4xl md:text-5xl mb-4">
        {{ heading | escape }}
      </h2>
    {% endif %}
    {% if description != blank %}
      <p class="ricette-header-item ricette-delay-2 text-muted-foreground text-sm max-w-lg mx-auto leading-relaxed recipes-header-section__description">
        {{ description | escape }}
      </p>
    {% endif %}
  </div>
</section>

{% style %}
  .recipes-header-section__description {
    display: block;
  }
  @media (prefers-reduced-motion: reduce) {
    .recipes-header-section .ricette-header-item {
      opacity: 1;
      animation: none;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Page header",
  "tag": "section",
  "class": "recipes-header-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "info": "Small uppercase label above the heading."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (H2)",
      "info": "Main heading (e.g. Le mie ricette)."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "info": "Paragraph below the heading (max-w-lg, centered)."
    }
  ],
  "presets": [
    {
      "name": "Page header"
    }
  ]
}
{% endschema %}
