{% liquid
  assign hero_image = section.settings.image
  assign hero_image_mobile = section.settings.image_mobile
  assign eyebrow = section.settings.eyebrow | default: 'Cucina italiana in conserva'
  assign title = section.settings.title | default: shop.name
  assign description = section.settings.description
  assign button_label = section.settings.button_label
  assign button_link = section.settings.button_link
  assign show_logo = section.settings.show_logo
  assign logo_image = section.settings.logo_image
  if logo_image == blank and show_logo
    assign logo_image = settings.logo
  endif
%}

{% style %}
  .hero-section .hero-section-wrapper {
    aspect-ratio: {% if hero_image != blank %}{{ hero_image.width }}/{{ hero_image.height }}{% else %}16/9{% endif %};
  }
  @media (max-width: 749px) {
    .hero-section .hero-section-wrapper {
      aspect-ratio: {% if hero_image_mobile != blank %}{{ hero_image_mobile.width }}/{{ hero_image_mobile.height }}{% elsif hero_image != blank %}{{ hero_image.width }}/{{ hero_image.height }}{% else %}16/9{% endif %};
    }
    .hero-section .hero-section-wrapper.no_mobile_image_available {
      min-height: 80dvh;
    }
  }
{% endstyle %}

<!-- Hero: height from image aspect ratio (desktop image on desktop, mobile image on mobile when set) -->
<section
  class="relative w-full flex items-end overflow-hidden hero-section-wrapper{% if hero_image_mobile == blank %} no_mobile_image_available{% endif %}"
  aria-label="{{ title | escape }}"
>
  <div class="absolute inset-0 hero-scale-wrap hero-section__bg">
    {% if hero_image != blank %}
      <div class="absolute inset-0 w-full h-full {% if hero_image_mobile != blank %}hidden--mobile{% endif %}">
        {% assign hero_alt = hero_image.alt | default: title %}
        {{ hero_image
          | image_url: width: 3840
          | image_tag:
            width: hero_image.width,
            widths: '832, 1200, 1600, 1920, 2560, 3840',
            height: hero_image.height,
            sizes: '100vw',
            alt: hero_alt,
            class: 'w-full h-full object-cover',
            fetchpriority: 'high'
        }}
      </div>
    {% endif %}
    {% if hero_image_mobile != blank %}
      <div class="absolute inset-0 w-full h-full {% if hero_image != blank %}hidden--desktop{% endif %}">
        {% assign mobile_alt = hero_image_mobile.alt | default: hero_image.alt | default: title %}
        {{ hero_image_mobile
          | image_url: width: 1600
          | image_tag:
            width: hero_image_mobile.width,
            widths: '414, 750, 828, 1080, 1200, 1600',
            height: hero_image_mobile.height,
            sizes: '100vw',
            alt: mobile_alt,
            class: 'w-full h-full object-cover',
            fetchpriority: 'high'
        }}
      </div>
    {% endif %}
    {% if hero_image == blank and hero_image_mobile == blank %}
      <div class="w-full h-full bg-primary object-cover" style="background-color: hsl(var(--primary));"></div>
    {% endif %}
    <div class="absolute inset-0 hero-overlay"></div>
  </div>
  <div class="relative z-10 max-w-7xl mx-auto px-6 pb-16 w-full">
    {% if eyebrow != blank %}
      <p class="hero-item hero-delay-0 text-[10px] font-sans font-medium uppercase tracking-[0.3em] text-primary-foreground/60 mb-3">
        {{ eyebrow | escape }}
      </p>
    {% endif %}
    <div class="hero-item hero-delay-1 flex items-center gap-5 mb-2">
      {% if show_logo and logo_image != blank %}
        <img
          src="{{ logo_image | image_url: width: 224 }}"
          alt="{{ shop.name | escape }}"
          class="h-20 md:h-28 w-auto drop-shadow-lg"
          width="{{ logo_image.width }}"
          height="{{ logo_image.height }}"
          loading="eager"
        >
      {% endif %}
      <h1 class="font-serif text-4xl md:text-6xl lg:text-7xl text-primary-foreground leading-[1.1]">
        {{ title | escape }}
      </h1>
    </div>
    {% if description != blank %}
      <p class="hero-item hero-delay-2 mt-4 text-sm md:text-base text-primary-foreground/70 max-w-md leading-relaxed">
        {{ description | escape }}
      </p>
    {% endif %}
    {% if button_label != blank %}
      <div class="hero-item hero-delay-3">
        <a
          href="{{ button_link | default: '#prodotti' }}"
          class="inline-block mt-8 text-[10px] font-sans font-medium uppercase tracking-[0.2em] text-primary-foreground border-b border-primary-foreground/40 pb-1 hover:border-primary-foreground transition-colors"
        >
          {{ button_label | escape }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "hero-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image (desktop)",
      "info": "Recommended: high resolution (e.g. 1920×1080 or larger). Scale-in animation on load."
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Background image (mobile)",
      "info": "Optional. When set, shown on viewports ≤749px; desktop image shown on larger screens. Section height uses each image's aspect ratio."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Cucina italiana in conserva",
      "info": "Small uppercase line above the title (hero-delay-0)."
    },
    {
      "type": "checkbox",
      "id": "show_logo",
      "label": "Show logo next to title",
      "default": true,
      "info": "Uses logo image below, or theme logo if blank."
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo image (optional)",
      "info": "Leave blank to use the theme logo from Theme settings."
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title (H1)",
      "default": "Guido Borrello",
      "info": "Main heading (hero-delay-1)."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "La qualità richiede tempo. Ogni sugo nasce da una ricetta tradizionale italiana.",
      "info": "Paragraph below title (hero-delay-2)."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Scopri i prodotti",
      "info": "Link text (hero-delay-3). Leave blank to hide."
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "info": "e.g. #prodotti or a collection/page URL. Fallback: #prodotti."
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "settings": {
        "eyebrow": "Cucina italiana in conserva",
        "show_logo": true,
        "title": "Guido Borrello",
        "description": "La qualità richiede tempo. Ogni sugo nasce da una ricetta tradizionale italiana.",
        "button_label": "Scopri i prodotti",
        "button_link": ""
      }
    }
  ]
}
{% endschema %}
