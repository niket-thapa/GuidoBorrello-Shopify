{% liquid
  assign menu_left_handle = section.settings.menu_left | default: 'main-menu'
  assign menu_right_handle = section.settings.menu_right | default: 'main-menu'
  assign menu_mobile_handle = section.settings.menu_mobile | default: 'main-menu'
  assign menu_left_linklist = linklists[menu_left_handle]
  assign menu_right_linklist = linklists[menu_right_handle]
  assign menu_mobile_linklist = linklists[menu_mobile_handle]
  if menu_left_linklist == blank
    assign menu_left_linklist = linklists['main-menu']
  endif
  if menu_right_linklist == blank
    assign menu_right_linklist = linklists['main-menu']
  endif
  if menu_mobile_linklist == blank
    assign menu_mobile_linklist = linklists['main-menu']
  endif

  capture logo_block
    content_for 'block', type: '_header-logo', id: 'header-logo'
  endcapture

  capture actions
    render 'header-actions'
  endcapture
%}

<script type="application/ld+json">
{
  "@context": "http://schema.org",
  "@type": "Organization",
  "name": {{ shop.name | json }},
  {% if settings.logo %}
    "logo": {{ settings.logo | image_url: width: 500 | prepend: "https:" | json }},
  {% endif %}
  "url": {{ request.origin | append: page.url | json }}
}
</script>

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 bg-background/80 backdrop-blur-md border-b border-border">
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between relative">
    <!-- Mobile menu toggle (hamburger) -->
    <button type="button" class="md:hidden text-foreground" aria-label="{{ 'accessibility.menu' | t }}" aria-expanded="false" aria-controls="mobile-nav" id="mobile-menu-btn">
      <span class="icon-menu" aria-hidden="true">
        {% render 'icon-gb-menu' %}
      </span>
      <span class="icon-close hidden" aria-hidden="true">
        {% render 'icon-gb-close' %}
      </span>
    </button>

    <!-- Desktop nav left - same as reference -->
    <nav class="hidden md:flex items-center gap-8 flex-1 justify-end pr-16" aria-label="{{ 'accessibility.menu' | t }}">
      {% if menu_left_linklist and menu_left_linklist.links.size > 0 %}
        {% for link in menu_left_linklist.links %}
          <a href="{{ link.url }}" class="text-xs font-sans font-medium uppercase tracking-[0.15em] text-muted-foreground hover:text-foreground transition-colors whitespace-nowrap{% if link.active %} text-foreground{% endif %}" {% if link.active %}aria-current="page"{% endif %}>{{ link.title | escape }}</a>
        {% endfor %}
      {% else %}
        <a href="{{ routes.root_url }}" class="text-xs font-sans font-medium uppercase tracking-[0.15em] text-muted-foreground hover:text-foreground transition-colors whitespace-nowrap">{{ 'general.home' | t }}</a>
      {% endif %}
    </nav>

    <!-- Logo (desktop) - same as reference -->
    <div class="flex-shrink-0 hidden md:block">
      {% if logo_block != blank %}
        {{ logo_block }}
      {% else %}
        <a href="{{ routes.root_url }}" class="flex-shrink-0 block">
          {% if settings.logo %}
            <img src="{{ settings.logo | image_url: width: 200 }}" alt="{{ shop.name | escape }}" class="h-10 w-auto" width="{{ settings.logo.width }}" height="{{ settings.logo.height }}" loading="eager" />
          {% else %}
            <span class="text-xs font-sans font-medium uppercase tracking-[0.15em] text-foreground">{{ shop.name }}</span>
          {% endif %}
        </a>
      {% endif %}
    </div>
    <!-- Logo (mobile, centered) - same as reference -->
    <div class="md:hidden absolute left-1/2 -translate-x-1/2">
      {% if logo_block != blank %}
        {{ logo_block }}
      {% else %}
        <a href="{{ routes.root_url }}" class="block">
          {% if settings.logo %}
            <img src="{{ settings.logo | image_url: width: 200 }}" alt="{{ shop.name | escape }}" class="h-10 w-auto" width="{{ settings.logo.width }}" height="{{ settings.logo.height }}" loading="eager" />
          {% else %}
            <span class="text-xs font-sans font-medium uppercase tracking-[0.15em] text-foreground">{{ shop.name }}</span>
          {% endif %}
        </a>
      {% endif %}
    </div>

    <!-- Desktop nav right + cart - same as reference -->
    <nav class="hidden md:flex items-center gap-8 flex-1 pl-16" aria-label="{{ 'accessibility.menu' | t }}">
      {% if menu_right_linklist and menu_right_linklist.links.size > 0 %}
        {% for link in menu_right_linklist.links %}
          <a href="{{ link.url }}" class="text-xs font-sans font-medium uppercase tracking-[0.15em] text-muted-foreground hover:text-foreground transition-colors whitespace-nowrap{% if link.active %} text-foreground{% endif %}" {% if link.active %}aria-current="page"{% endif %}>{{ link.title | escape }}</a>
        {% endfor %}
      {% else %}
        <a href="{{ routes.root_url }}" class="text-xs font-sans font-medium uppercase tracking-[0.15em] text-muted-foreground hover:text-foreground transition-colors whitespace-nowrap">{{ 'general.home' | t }}</a>
      {% endif %}
      <span class="relative text-foreground hover:text-accent transition-colors ml-auto">
        {{ actions }}
      </span>
    </nav>

    <!-- Mobile cart -->
    <div class="md:hidden relative text-foreground hover:text-accent transition-colors">
      {{ actions }}
    </div>
  </div>

  <!-- Mobile menu (inline) - same as reference -->
  <nav id="mobile-nav" class="md:hidden bg-background border-b border-border px-6 pb-6 pt-2 space-y-4" aria-label="{{ 'accessibility.menu' | t }}">
    {% if menu_mobile_linklist and menu_mobile_linklist.links.size > 0 %}
      {% for link in menu_mobile_linklist.links %}
        <a href="{{ link.url }}" class="block text-sm font-sans font-medium uppercase tracking-[0.15em] text-muted-foreground hover:text-foreground transition-colors{% if link.active %} text-foreground{% endif %}" {% if link.active %}aria-current="page"{% endif %}>{{ link.title | escape }}</a>
      {% endfor %}
    {% else %}
      <a href="{{ routes.root_url }}" class="block text-sm font-sans font-medium uppercase tracking-[0.15em] text-muted-foreground hover:text-foreground transition-colors">{{ 'general.home' | t }}</a>
    {% endif %}
  </nav>
</header>

<script>
  (function() {
    var header = document.getElementById('site-header');
    var btn = document.getElementById('mobile-menu-btn');
    var mobileNav = document.getElementById('mobile-nav');
    if (!header || !btn || !mobileNav) return;
    btn.addEventListener('click', function() {
      header.classList.toggle('mobile-menu-open');
      var open = header.classList.contains('mobile-menu-open');
      btn.setAttribute('aria-expanded', open);
      btn.querySelector('.icon-menu').classList.toggle('hidden', open);
      btn.querySelector('.icon-close').classList.toggle('hidden', !open);
    });
  })();
</script>

{% schema %}
{
  "name": "Header",
  "tag": "div",
  "class": "header-section",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "_header-logo"
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Menus"
    },
    {
      "type": "link_list",
      "id": "menu_left",
      "label": "Menu (left)",
      "default": "main-menu",
      "info": "Desktop links to the left of the logo."
    },
    {
      "type": "link_list",
      "id": "menu_right",
      "label": "Menu (right)",
      "default": "main-menu",
      "info": "Desktop links to the right of the logo."
    },
    {
      "type": "link_list",
      "id": "menu_mobile",
      "label": "Menu (mobile)",
      "default": "main-menu",
      "info": "Links in the mobile menu."
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#faf8f5"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e8e4dc"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "select",
      "id": "header_height",
      "label": "Height",
      "options": [
        { "value": "standard", "label": "Standard" },
        { "value": "compact", "label": "Compact" }
      ],
      "default": "standard"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "select",
      "id": "sticky_header",
      "label": "Sticky header",
      "options": [
        { "value": "always", "label": "Always" },
        { "value": "scroll-up", "label": "On scroll up" },
        { "value": "never", "label": "Never" }
      ],
      "default": "always"
    },
    {
      "type": "header",
      "content": "Mobile drawer"
    },
    {
      "type": "color_scheme",
      "id": "drawer_color_scheme",
      "label": "Drawer background",
      "default": "scheme-1"
    }
  ],
  "presets": []
}
{% endschema %}
