{% liquid
  assign heading = section.settings.heading
  assign paragraph = section.settings.paragraph
  assign button_label = section.settings.button_label
  assign button_link = section.settings.button_link
  assign aos_margin = section.settings.aos_margin | default: '-60'
%}

{% comment %} CTA – same structure and animation as reference {% endcomment %}
<section class="py-24 overflow-hidden cta-section" {{ section.shopify_attributes }}>
  <div class="max-w-2xl mx-auto px-6 text-center aos-group" data-aos-margin="{{ aos_margin }}">
    {% if heading != blank %}
      <h2 class="aos font-serif text-3xl md:text-4xl mb-4 italic" data-aos-delay="0">{{ heading | escape }}</h2>
    {% endif %}
    {% if paragraph != blank %}
      <p class="aos text-muted-foreground text-sm leading-relaxed mb-8" data-aos-delay="1">{{ paragraph | escape }}</p>
    {% endif %}
    {% if button_label != blank %}
      <div class="aos" data-aos-delay="2">
        <a href="{{ button_link | default: '#' }}" class="inline-block text-[10px] font-sans font-medium uppercase tracking-[0.2em] text-foreground border-b border-foreground/40 pb-1 hover:border-foreground transition-colors">
          {{ button_label | escape }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

<script src="{{ 'aos.js' | asset_url }}" type="module" defer></script>

{% schema %}
{
  "name": "CTA",
  "tag": "section",
  "class": "cta-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "paragraph",
      "label": "Paragraph"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "aos_margin",
      "label": "Scroll margin (px)",
      "default": "-60",
      "info": "Trigger margin for animate-on-scroll."
    }
  ],
  "presets": [
    {
      "name": "CTA",
      "settings": {}
    }
  ]
}
{% endschema %}
