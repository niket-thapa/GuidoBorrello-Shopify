{% liquid
  assign eyebrow = section.settings.eyebrow
  assign heading = section.settings.heading
  assign description = section.settings.description
  assign aos_margin = section.settings.aos_margin
  if aos_margin == blank
    assign aos_margin = '0'
  endif
%}

<!-- Contact hero – same structure and animations as reference (contatti.html) -->
<section class="py-20 md:py-28 contact-hero-section" {{ section.shopify_attributes }}>
  <div class="max-w-7xl mx-auto px-6">
    <div class="max-w-2xl contact-hero-section__header aos-group" data-aos-margin="{{ aos_margin }}">
      {% if eyebrow != blank %}
        <p class="aos text-[10px] font-sans font-medium uppercase tracking-[0.3em] text-muted-foreground mb-3" data-aos-delay="0">{{ eyebrow | escape }}</p>
      {% endif %}
      {% if heading != blank %}
        <h2 class="aos font-serif text-4xl md:text-5xl lg:text-6xl leading-[1.1] mb-6" data-aos-delay="1">{{ heading | escape }}</h2>
      {% endif %}
      {% if description != blank %}
        <p class="aos text-muted-foreground leading-relaxed text-base contact-hero-section__description" data-aos-delay="2">{{ description | escape }}</p>
      {% endif %}
    </div>
  </div>
</section>

<script src="{{ 'aos.js' | asset_url }}" type="module" defer></script>

{% schema %}
{
  "name": "Contact hero",
  "tag": "section",
  "class": "contact-hero-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "info": "Small uppercase label above the heading."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (H2)",
      "info": "Main heading. Page has one H1 in the header."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "info": "Paragraph below the heading."
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "text",
      "id": "aos_margin",
      "label": "Scroll margin (px)",
      "info": "Trigger margin for animate-on-scroll (e.g. 0). Leave blank for 0."
    }
  ],
  "presets": [
    {
      "name": "Contact hero"
    }
  ]
}
{% endschema %}
