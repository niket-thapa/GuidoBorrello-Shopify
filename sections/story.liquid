{% liquid
  assign eyebrow = section.settings.eyebrow
  assign heading = section.settings.heading
  assign paragraph_1 = section.settings.paragraph_1
  assign image = section.settings.image
  assign aos_margin = section.settings.aos_margin | default: '-80'
%}

<!-- Story – same structure and animations as reference -->
<section class="py-24 md:py-32 overflow-hidden story-section" {{ section.shopify_attributes }}>
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <div class="aos-group" data-aos-margin="{{ aos_margin }}">
        {% if eyebrow != blank %}
          <p class="aos text-[10px] font-sans font-medium uppercase tracking-[0.3em] text-muted-foreground mb-4" data-aos-delay="0">{{ eyebrow | escape }}</p>
        {% endif %}
        {% if heading != blank %}
          <h2 class="aos font-serif text-3xl md:text-4xl leading-tight mb-6" data-aos-delay="1">{{ heading | escape }}</h2>
        {% endif %}
        {% if paragraph_1 != blank %}
          <div class="aos text-muted-foreground leading-relaxed story-section__richtext" data-aos-delay="2">{{ paragraph_1 }}</div>
        {% endif %}
      </div>
      <div class="aos aos-slide-right aspect-[4/5] overflow-hidden rounded-sm" data-aos-margin="{{ aos_margin }}">
        {% if image != blank %}
          {{
            image
            | image_url: width: 1200
            | image_tag:
              width: image.width,
              widths: '400, 500, 600, 800, 1000, 1200',
              sizes: '(min-width: 768px) 50vw, 100vw',
              alt: image.alt | default: heading | default: 'Story image',
              class: 'story-section__image',
              loading: 'lazy'
          }}
        {% else %}
          <div class="w-full h-full bg-card" style="background-color: hsl(var(--card));"></div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<script src="{{ 'aos.js' | asset_url }}" type="module" defer></script>

{% style %}
  .story-section .grid {
    grid-template-areas: none;
  }
  .story-section__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .story-section__richtext p {
    margin: 0 0 0.5em;
  }
  .story-section__richtext p:last-child {
    margin-bottom: 0;
  }
{% endstyle %}

{% schema %}
{
  "name": "Story",
  "tag": "section",
  "class": "story-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Label",
      "info": "Small uppercase label above the heading."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Main heading (H2)."
    },
    {
      "type": "richtext",
      "id": "paragraph_1",
      "label": "Paragraph"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Right column image (aspect 4:5)."
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "text",
      "id": "aos_margin",
      "label": "Scroll margin (px)",
      "default": "-80",
      "info": "Trigger margin for animate-on-scroll (e.g. -80). Same as reference data-aos-margin."
    }
  ],
  "presets": [
    {
      "name": "Story",
      "settings": {}
    }
  ]
}
{% endschema %}
