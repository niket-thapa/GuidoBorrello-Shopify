{% liquid
  assign eyebrow = section.settings.eyebrow
  assign heading = section.settings.heading
  assign aos_margin = section.settings.aos_margin
  if aos_margin == blank
    assign aos_margin = '-60'
  endif
%}

<!-- Services – same structure and animations as reference (consulenze) -->
<section class="py-20 bg-card services-section" {{ section.shopify_attributes }}>
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16 aos-group" data-aos-margin="{{ aos_margin }}">
      {% if eyebrow != blank %}
        <p class="aos text-[10px] font-sans font-medium uppercase tracking-[0.3em] text-muted-foreground mb-3" data-aos-delay="0">{{ eyebrow | escape }}</p>
      {% endif %}
      {% if heading != blank %}
        <h2 class="aos font-serif text-3xl md:text-4xl" data-aos-delay="1">{{ heading | escape }}</h2>
      {% endif %}
    </div>

    <div class="grid md:grid-cols-3 gap-8 aos-group" data-aos-margin="{{ aos_margin }}">
      {% for block in section.blocks %}
        {% if block.type == 'service' %}
          {% liquid
            assign icon = block.settings.icon
            assign title = block.settings.title
            assign description = block.settings.description
            assign delay_index = forloop.index0
          %}
          <div
            class="aos p-8 bg-background border border-border text-center hover:shadow-lg transition-shadow services-section__card"
            data-aos-delay="{{ delay_index }}"
            {{ block.shopify_attributes }}
          >
            {% if icon != blank or title != blank or description != blank %}
              {% if icon != blank %}
                {% assign icon_alt = icon.alt | default: title | default: 'Icon' %}
                <div class="w-14 h-14 rounded-full bg-accent/10 mx-auto mb-5 flex items-center justify-center services-section__icon-wrap">
                  {{
                    icon
                    | image_url: width: 112
                    | image_tag:
                      width: icon.width,
                      heights: '56, 112',
                      sizes: '3.5rem',
                      alt: icon_alt,
                      class: 'services-section__icon text-accent w-6 h-6',
                      loading: 'lazy'
                  }}
                </div>
              {% endif %}
              {% if title != blank %}
                <h3 class="font-serif text-xl mb-3">{{ title | escape }}</h3>
              {% endif %}
              {% if description != blank %}
                <div class="text-sm text-muted-foreground leading-relaxed services-section__richtext">{{ description }}</div>
              {% endif %}
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% style %}
  .services-section .grid {
    grid-template-areas: none;
  }
  .services-section__icon-wrap {
    min-width: 3.5rem;
    min-height: 3.5rem;
  }
  .services-section__icon {
    width: 1.5rem;
    height: 1.5rem;
    object-fit: contain;
  }
  .services-section__richtext p {
    margin: 0 0 0.5em;
  }
  .services-section__richtext p:last-child {
    margin-bottom: 0;
  }
{% endstyle %}

{% schema %}
{
  "name": "Services",
  "tag": "section",
  "class": "services-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "info": "Small uppercase label above the heading."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (H2)",
      "info": "Main section heading."
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "text",
      "id": "aos_margin",
      "label": "Scroll margin (px)",
      "info": "Trigger margin for animate-on-scroll (e.g. -60). Leave blank for -60."
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon / image",
          "info": "Image or icon for the card (shown in accent circle)."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title (H3)"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Services",
      "blocks": []
    }
  ]
}
{% endschema %}
