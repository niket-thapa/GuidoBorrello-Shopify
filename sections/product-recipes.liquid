{% comment %}
  Product Recipes – shows all articles from a selected blog. On product template, shows
  "Con questo prodotto" badge only when the article is in product.metafields.custom.recipe.
{% endcomment %}

{% liquid
  assign show_section = false
  assign selected_blog = section.settings.blog
  if selected_blog != blank
    assign recipes_blog = blogs[selected_blog]
    if recipes_blog != blank and recipes_blog.articles.size > 0
      assign show_section = true
    endif
  endif
  assign product_recipe_list = null
  assign accent_color = '#8b3a3a'
  if request.page_type == 'product' and product != blank
    assign recipe_metafield = product.metafields.custom.recipe | default: product.metafields.custom.recipes
    assign product_recipe_list = recipe_metafield.value
    if product_recipe_list == blank and recipe_metafield != blank
      assign product_recipe_list = recipe_metafield
    endif
    assign accent_color = product.metafields.custom.product_color | default: '#8b3a3a'
  endif
%}

{% if show_section %}
  {% assign recipes_blog = blogs[section.settings.blog] %}
  <section class="product-recipes py-20 bg-card" {{ section.shopify_attributes }}>
    <div class="product-recipes__inner max-w-7xl mx-auto px-6 product-detail-stagger aos-group" data-aos-margin="-60">
      <div class="aos product-recipes__head flex items-end justify-between mb-12" data-aos-delay="0">
        <div>
          <p class="product-recipes__tagline text-[10px] font-sans font-medium uppercase tracking-[0.3em] text-muted-foreground mb-3">{{ section.settings.tagline }}</p>
          <h2 class="product-recipes__title font-serif text-3xl md:text-4xl">{{ section.settings.section_title }}</h2>
        </div>
        <div class="product-recipes__nav product-recipes__nav--desktop hidden md:flex items-center gap-2">
          <button type="button" class="recipes-prev product-recipes__btn w-10 h-10 rounded-full border border-border flex items-center justify-center hover:bg-background transition-colors" aria-label="{{ section.settings.aria_prev | default: 'Ricetta precedente' }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <button type="button" class="recipes-next product-recipes__btn w-10 h-10 rounded-full border border-border flex items-center justify-center hover:bg-background transition-colors" aria-label="{{ section.settings.aria_next | default: 'Ricetta successiva' }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        </div>
      </div>
      <div class="aos product-recipes__carousel-wrap recipes-carousel-wrap" data-aos-delay="1">
        <div class="product-recipes__carousel-outer overflow-hidden" id="product-recipes-carousel-{{ section.id }}">
          <div class="product-recipes__track recipes-track flex gap-6" role="list">
            {% for article in recipes_blog.articles %}
              {% assign show_badge = false %}
              {% if product_recipe_list != blank and product != blank %}
                {% for item in product_recipe_list %}
                  {% assign ref_article = item.value | default: item %}
                  {% if ref_article.id == article.id %}
                    {% assign show_badge = true %}
                    {% break %}
                  {% endif %}
                {% endfor %}
              {% endif %}
              <div class="product-recipes__slide flex-none w-[85%] sm:w-[45%] md:w-[30%]" role="listitem">
                <a href="{{ article.url }}" class="product-recipes__card group block overflow-hidden border border-border bg-background hover:shadow-xl transition-all duration-500">
                  <div class="product-recipes__card-aspect aspect-[16/10] overflow-hidden">
                    {% if article.image %}
                      {% assign recipe_img_alt = article.image.alt | default: article.title | escape %}
                      {{
                        article.image
                        | image_url: width: 600
                        | image_tag:
                          loading: 'lazy',
                          alt: recipe_img_alt,
                          class: 'product-recipes__card-img w-full h-full object-cover group-hover:scale-105 transition-transform duration-700',
                          widths: '300, 400, 600',
                          sizes: '(min-width: 990px) 30vw, (min-width: 750px) 45vw, 85vw'
                      }}
                    {% else %}
                      {{ 'image' | placeholder_svg_tag: 'product-recipes__card-img w-full h-full object-cover product-recipes__card-placeholder' }}
                    {% endif %}
                  </div>
                  <div class="product-recipes__card-content p-5">
                    {% assign has_meta = false %}
                    {% if article.metafields.custom.prep_time != blank or article.metafields.custom.servings != blank or article.metafields.custom.difficulty != blank %}
                      {% assign has_meta = true %}
                    {% endif %}
                    {% if has_meta %}
                      <div class="product-recipes__card-meta flex items-center gap-3 text-[9px] font-sans uppercase tracking-[0.2em] text-muted-foreground mb-3">
                        {% if article.metafields.custom.prep_time != blank %}
                          <span class="flex items-center gap-1">
                            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            {{ article.metafields.custom.prep_time | escape }}
                          </span>
                        {% endif %}
                        {% if article.metafields.custom.servings != blank %}
                          <span class="flex items-center gap-1">
                            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                            {{ article.metafields.custom.servings | escape }}
                          </span>
                        {% endif %}
                        {% if article.metafields.custom.difficulty != blank %}
                          <span class="flex items-center gap-1">
                            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21a1 1 0 0 0 1-1v-5.35c0-.457.316-.844.727-1.041a4 4 0 0 0-2.134-7.589 5 5 0 0 0-9.186 0 4 4 0 0 0-2.134 7.588c.411.198.727.585.727 1.041V20a1 1 0 0 0 1 1Z"/><path d="M6 17h12"/></svg>
                            {{ article.metafields.custom.difficulty | escape }}
                          </span>
                        {% endif %}
                      </div>
                    {% endif %}
                    <h3 class="product-recipes__card-title font-serif text-lg mb-1.5 group-hover:opacity-70 transition-opacity">{{ article.title | escape }}</h3>
                    <p class="product-recipes__card-excerpt text-xs text-muted-foreground leading-relaxed line-clamp-2">{{ article.excerpt | default: article.content | strip_html | truncate: 120 }}</p>
                    {% if show_badge %}
                      <span class="product-recipes__card-badge inline-block mt-3 text-[9px] font-sans font-medium uppercase tracking-[0.15em] px-2.5 py-1 rounded-full" style="background: {{ accent_color }}1a; color: {{ accent_color }};">{{ section.settings.badge_text }}</span>
                    {% endif %}
                  </div>
                </a>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
      <div class="aos product-recipes__nav product-recipes__nav--mobile flex md:hidden items-center justify-center gap-3 mt-8" data-aos-delay="2">
        <button type="button" class="recipes-prev product-recipes__btn w-10 h-10 rounded-full border border-border flex items-center justify-center hover:bg-background transition-colors" aria-label="{{ section.settings.aria_prev | default: 'Ricetta precedente' }}">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <button type="button" class="recipes-next product-recipes__btn w-10 h-10 rounded-full border border-border flex items-center justify-center hover:bg-background transition-colors" aria-label="{{ section.settings.aria_next | default: 'Ricetta successiva' }}">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
        </button>
      </div>
    </div>
  </section>

  <script>
    (function () {
      function initRecipesSlider() {
        var sectionId = '{{ section.id }}';
        var container = document.getElementById('product-recipes-carousel-' + sectionId);
        if (!container) return;
        var track = container.querySelector('.product-recipes__track');
        if (!track) return;
        var cards = track.querySelectorAll('.product-recipes__slide');
        if (cards.length === 0) return;
        var wrap = container.closest('.product-recipes');
        if (!wrap) return;
        var gap = 24;
        var index = 0;
        var maxIndex = Math.max(0, cards.length - 1);
        function getStep() {
          return cards[0] ? cards[0].offsetWidth + gap : 0;
        }
        function updateTransform() {
          var step = getStep();
          if (step <= 0) return;
          var offset = -index * step;
          track.style.transform = 'translate3d(' + offset + 'px, 0, 0)';
          track.style.transition = 'transform 0.4s ease-out';
        }
        function scroll(dir) {
          index = index + dir;
          if (index < 0) index = 0;
          if (index > maxIndex) index = maxIndex;
          updateTransform();
        }
        updateTransform();
        requestAnimationFrame(function () {
          requestAnimationFrame(updateTransform);
        });
        var resizeTimer;
        window.addEventListener('resize', function () {
          clearTimeout(resizeTimer);
          resizeTimer = setTimeout(updateTransform, 100);
        });
        wrap.querySelectorAll('.recipes-prev').forEach(function (btn) {
          btn.removeEventListener('click', btn._recipesScrollPrev);
          btn._recipesScrollPrev = function () { scroll(-1); };
          btn.addEventListener('click', btn._recipesScrollPrev);
        });
        wrap.querySelectorAll('.recipes-next').forEach(function (btn) {
          btn.removeEventListener('click', btn._recipesScrollNext);
          btn._recipesScrollNext = function () { scroll(1); };
          btn.addEventListener('click', btn._recipesScrollNext);
        });
        if (cards.length > 1) {
          wrap.querySelectorAll('.product-recipes__nav').forEach(function (nav) {
            nav.classList.remove('hidden');
          });
        }
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initRecipesSlider);
      } else {
        initRecipesSlider();
      }
    })();
  </script>
{% endif %}

{% stylesheet %}
  /* Match reference: py-20 bg-card, max-w-7xl mx-auto px-6. AOS handled by theme .aos-group / .aos */
  .product-recipes {
    padding-top: 5rem;
    padding-bottom: 5rem;
    background: hsl(var(--card, 0 0% 98%));
  }

  .product-recipes__inner {
    max-width: 80rem;
    margin-left: auto;
    margin-right: auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  .product-recipes__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 3rem;
  }

  .product-recipes__tagline {
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground, 0 0 0) / 0.7);
    margin: 0 0 0.75rem;
  }

  .product-recipes__title {
    font-family: var(--font-heading--family, Georgia, serif);
    font-size: 1.875rem;
    margin: 0;
  }

  @media screen and (min-width: 768px) {
    .product-recipes__title {
      font-size: 2.25rem;
    }
  }

  .product-recipes__nav--desktop {
    display: none;
    align-items: center;
    gap: 0.5rem;
  }

  @media screen and (min-width: 768px) {
    .product-recipes__nav--desktop {
      display: flex;
    }
  }

  .product-recipes__nav--mobile {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  @media screen and (min-width: 768px) {
    .product-recipes__nav--mobile {
      display: none;
    }
  }

  .product-recipes__btn {
    width: 2.5rem;
    height: 2.5rem;
    min-width: 2.5rem;
    min-height: 2.5rem;
    border-radius: 9999px;
    border: 1px solid hsl(var(--border, 0 0% 90%));
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .product-recipes__btn:hover {
    background: var(--color-background, 255 255 255);
  }

  .product-recipes__carousel-outer {
    overflow: hidden;
  }

  .product-recipes__track {
    display: flex;
    gap: 1.5rem;
    will-change: transform;
  }

  .product-recipes__slide {
    flex: 0 0 85%;
    width: 85%;
    flex-shrink: 0;
  }

  @media screen and (min-width: 640px) {
    .product-recipes__slide {
      flex: 0 0 45%;
      width: 45%;
    }
  }

  @media screen and (min-width: 990px) {
    .product-recipes__slide {
      flex: 0 0 30%;
      width: 30%;
    }
  }

  /* Card: reference hover:shadow-xl transition-all duration-500 */
  .product-recipes__card {
    display: block;
    overflow: hidden;
    border-radius: 2px;
    border: 1px solid hsl(var(--border, 0 0% 90%));
    background: var(--color-background, 255 255 255);
    transition: all 0.5s ease;
  }

  .product-recipes__card:hover {
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
  }

  .product-recipes__card-aspect {
    aspect-ratio: 16 / 10;
  }

  .product-recipes__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }

  .product-recipes__card:hover .product-recipes__card-img {
    transform: scale(1.05);
  }

  .product-recipes__card-placeholder {
    background: var(--color-background-card, 245 245 245);
  }

  .product-recipes__card-content {
    padding: 1.25rem;
  }

  .product-recipes__card-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    font-size: 0.5625rem;
    font-family: var(--font-body--family, system-ui, sans-serif);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgb(var(--color-foreground, 0 0 0) / 0.7);
  }

  .product-recipes__card-meta .flex {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .product-recipes__card-title {
    font-family: var(--font-heading--family, Georgia, serif);
    font-size: 1.125rem;
    margin: 0 0 0.375rem;
    transition: opacity 0.2s ease;
  }

  .product-recipes__card:hover .product-recipes__card-title {
    opacity: 0.7;
  }

  .product-recipes__card-excerpt {
    font-size: 0.75rem;
    line-height: 1.625;
    color: rgb(var(--color-foreground, 0 0 0) / 0.7);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .product-recipes__card-badge {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.5625rem;
    font-family: var(--font-body--family, system-ui, sans-serif);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    padding: 0.25rem 0.625rem;
    border-radius: 9999px;
  }

  @media (prefers-reduced-motion: reduce) {
    .product-recipes__track {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product recipes",
  "tag": "section",
  "class": "section-product-recipes",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog",
      "info": "All articles from this blog are shown. On product pages, the badge appears only for recipes linked via product metafield custom.recipe."
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Le ricette"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section title",
      "default": "Preparalo così"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text (when recipe is linked to product)",
      "default": "Con questo prodotto"
    },
    {
      "type": "text",
      "id": "aria_prev",
      "label": "Previous button (aria-label)",
      "default": "Ricetta precedente"
    },
    {
      "type": "text",
      "id": "aria_next",
      "label": "Next button (aria-label)",
      "default": "Ricetta successiva"
    }
  ],
  "presets": [
    {
      "name": "Product recipes"
    }
  ]
}
{% endschema %}
