{% liquid
  assign hero_image = section.settings.image
  assign eyebrow = section.settings.eyebrow
  assign title = section.settings.title
%}

<!-- Sub page hero: same structure and animations as reference -->
<section class="relative h-[60vh] md:h-[70vh] flex items-end overflow-hidden sub-page-hero" aria-label="{{ title | default: 'Hero' | escape }}" {{ section.shopify_attributes }}>
  <div class="absolute inset-0 hero-scale-wrap-sub sub-page-hero__bg">
    {% if hero_image != blank %}
      {% assign hero_alt = hero_image.alt | default: title %}
      {{ hero_image
        | image_url: width: 3840
        | image_tag:
          width: hero_image.width,
          widths: '832, 1200, 1600, 1920, 2560, 3840',
          height: hero_image.height,
          sizes: '100vw',
          alt: hero_alt,
          class: 'w-full h-full object-cover',
          fetchpriority: 'high'
      }}
    {% else %}
      <div class="w-full h-full bg-primary object-cover" style="background-color: hsl(var(--primary));"></div>
    {% endif %}
    <div class="absolute inset-0 sub-page-hero-overlay"></div>
  </div>
  <div class="relative z-10 max-w-7xl mx-auto px-6 pb-16 w-full">
    {% if eyebrow != blank %}
      <p class="hero-item sub-page-delay-0 text-[10px] font-sans font-medium uppercase tracking-[0.3em] text-white/60 mb-3">
        {{ eyebrow | escape }}
      </p>
    {% endif %}
    {% if title != blank %}
      <h2 class="hero-item sub-page-delay-1 font-serif text-4xl md:text-6xl text-white leading-[1.1] max-w-2xl">
        {{ title | escape }}
      </h2>
    {% endif %}
  </div>
</section>

{% style %}
  .sub-page-hero__bg {
    overflow: hidden;
  }
  @media (prefers-reduced-motion: reduce) {
    .sub-page-hero .hero-scale-wrap-sub {
      animation: none;
    }
    .sub-page-hero .hero-item {
      opacity: 1;
      animation: none;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Sub page hero",
  "tag": "section",
  "class": "sub-page-hero-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image",
      "info": "Recommended: high resolution (e.g. 1920×1080). Scale-in animation on load."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "info": "Optional small uppercase line above the title. Leave blank to hide."
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title (H2)",
      "info": "Main heading for this section. Page has one H1 in the header."
    }
  ],
  "presets": [
    {
      "name": "Sub page hero"
    }
  ]
}
{% endschema %}
