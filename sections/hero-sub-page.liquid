{% liquid
  assign hero_image = section.settings.image
  assign hero_image_mobile = section.settings.image_mobile
  assign eyebrow = section.settings.eyebrow
  assign title = section.settings.title
%}

<!-- Sub page hero: same structure and animations as reference -->
<section class="relative h-[60vh] md:h-[70vh] flex items-end overflow-hidden sub-page-hero" aria-label="{{ title | default: 'Hero' | escape }}" {{ section.shopify_attributes }}>
  <div class="absolute inset-0 hero-scale-wrap-sub sub-page-hero__bg">
    {% if hero_image != blank %}
      <div class="absolute inset-0 w-full h-full {% if hero_image_mobile != blank %}hidden--mobile{% endif %}">
        {% assign hero_alt = hero_image.alt | default: title %}
        {{ hero_image
          | image_url: width: 3840
          | image_tag:
            width: hero_image.width,
            widths: '832, 1200, 1600, 1920, 2560, 3840',
            height: hero_image.height,
            sizes: '100vw',
            alt: hero_alt,
            class: 'w-full h-full object-cover',
            fetchpriority: 'high'
        }}
      </div>
    {% endif %}
    {% if hero_image_mobile != blank %}
      <div class="absolute inset-0 w-full h-full {% if hero_image != blank %}hidden--desktop{% endif %}">
        {% assign mobile_alt = hero_image_mobile.alt | default: hero_image.alt | default: title %}
        {{ hero_image_mobile
          | image_url: width: 1600
          | image_tag:
            width: hero_image_mobile.width,
            widths: '414, 750, 828, 1080, 1200, 1600',
            height: hero_image_mobile.height,
            sizes: '100vw',
            alt: mobile_alt,
            class: 'w-full h-full object-cover',
            fetchpriority: 'high'
        }}
      </div>
    {% endif %}
    {% if hero_image == blank and hero_image_mobile == blank %}
      <div class="w-full h-full bg-primary object-cover" style="background-color: hsl(var(--primary));"></div>
    {% endif %}
    <div class="absolute inset-0 sub-page-hero-overlay"></div>
  </div>
  <div class="relative z-10 max-w-7xl mx-auto px-6 pb-16 w-full">
    {% if eyebrow != blank %}
      <p class="hero-item sub-page-delay-0 text-[10px] font-sans font-medium uppercase tracking-[0.3em] text-white/60 mb-3">
        {{ eyebrow | escape }}
      </p>
    {% endif %}
    {% if title != blank %}
      <h2 class="hero-item sub-page-delay-1 font-serif text-4xl md:text-6xl text-white leading-[1.1] max-w-2xl">
        {{ title | escape }}
      </h2>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Sub page hero",
  "tag": "section",
  "class": "sub-page-hero-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image (desktop)",
      "info": "Recommended: high resolution (e.g. 1920×1080). Scale-in animation on load."
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Background image (mobile)",
      "info": "Optional. When set, this image is shown on mobile (≤749px) and the desktop image is shown on larger screens."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "info": "Optional small uppercase line above the title. Leave blank to hide."
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title (H2)",
      "info": "Main heading for this section. Page has one H1 in the header."
    }
  ],
  "presets": [
    {
      "name": "Sub page hero"
    }
  ]
}
{% endschema %}
